generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Player {
  id        Int          @id @default(autoincrement())
  fullName  String       @unique
  createdAt DateTime     @default(now())
  teams     TeamMember[]
}

model Submission {
  id             Int          @id @default(autoincrement())
  teamName       String
  score          Int
  totalQuestions Int
  answers        String
  weekendKey     String
  createdAt      DateTime     @default(now())
  members        TeamMember[]

  @@unique([teamName, weekendKey])
}

model TeamMember {
  id           Int        @id @default(autoincrement())
  submission   Submission @relation(fields: [submissionId], references: [id])
  submissionId Int
  player       Player     @relation(fields: [playerId], references: [id])
  playerId     Int

  @@unique([submissionId, playerId])
}
